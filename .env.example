# Exemplo de variáveis de ambiente
# Copie este arquivo para `.env` ou configure na plataforma de deploy

# Chave da API Gemini/GenAI (NÃO COMMITAR A CHAVE REAL)
# Substitua pelo seu valor local em `.env` ou via variáveis do ambiente.
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Outras variáveis de ambiente já usadas no projeto (exemplos)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
