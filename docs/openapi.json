    "/v1/audit/{entidade}/{id}": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "entidade",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
