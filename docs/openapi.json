          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/v1/reconciliacao/relatorio": {
      "get": {
        "summary": "Obter relatório de reconciliação",
        "tags": [
          "Reconciliação"
        ],
        "description": "Retorna estatísticas de reconciliação de parcelas com filtros opcionais de data e consignatária",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "date"
            },
            "in": "query",
            "name": "data_inicio",
            "required": false,
            "description": "Data inicial para filtro (YYYY-MM-DD)"
          },
          {
            "schema": {
              "type": "string",
              "format": "date"
            },
            "in": "query",
            "name": "data_fim",
            "required": false,
            "description": "Data final para filtro (YYYY-MM-DD)"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "consignataria_id",
            "required": false,
            "description": "ID da consignatária para filtro"
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Relatório de reconciliação obtido com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "number",
                          "description": "Total de parcelas processadas"
                        },
                        "byStatus": {
                          "type": "object",
                          "description": "Contagem por status: CONCILIADA, ERRO_FK, ERRO_VALOR, ERRO_ARQUIVO, PENDENTE",
                          "additionalProperties": {
                            "type": "number"
                          }
                        },
                        "byConsignataria": {
                          "type": "object",
                          "description": "Detalhamento por consignatária",
                          "additionalProperties": {
                            "type": "object",
                            "properties": {
                              "total": {
                                "type": "number"
                              },
                              "byStatus": {
                                "type": "object",
                                "additionalProperties": {
                                  "type": "number"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }
    }
  }
}