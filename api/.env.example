# Database Connection (PostgreSQL / Neon)
# Preferencialmente defina uma única connection string em DATABASE_URL
# Exemplo (Neon - pooler):
DATABASE_URL="postgresql://neondb_owner:senha@ep-spring-cake-ac9tv0lz-pooler.sa-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Caso precise rodar migrações sem pooler, defina DIRECT_URL (opcional)
DIRECT_URL="postgresql://neondb_owner:senha@ep-spring-cake-ac9tv0lz.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Alternativas reconhecidas pelo prisma (opcionais)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_URL=""

# Também suportamos separar partes da conexão (opcional)
POSTGRES_HOST=localhost
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha
POSTGRES_DATABASE=seu_banco

# JWT
JWT_SECRET="sua-chave-secreta-jwt-super-segura-aqui-min-32-chars"
JWT_EXPIRES_IN="8h"

# CORS / Origens permitidas
CORS_ORIGIN="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# Autenticação / limites
AUTH_MAX_TENTATIVAS=5
AUTH_BLOQUEIO_MINUTOS=30

# Server
PORT=3333
NODE_ENV="development"

# Frontend (útil para testes locais se frontend estiver em outra porta)
NEXT_PUBLIC_API_URL="http://localhost:3333/v1"

# Observação: não comite segredos reais em repositórios públicos.
