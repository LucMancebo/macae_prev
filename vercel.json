{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "api/index.ts",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ]
}
